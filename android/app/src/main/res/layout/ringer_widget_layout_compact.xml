<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rg_surface"
    android:baselineAligned="false"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center"
        android:minWidth="28dp"
        android:orientation="vertical"
        android:paddingEnd="6dp">

        <ImageView
            android:id="@+id/widget_status_dot"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@string/widget_status_indicator"
            android:src="@drawable/status_dot_green" />

        <Chronometer
            android:id="@+id/widget_status_chronometer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/rg_orange"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_status_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/rg_text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_btn_silence"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_orange"
            android:drawableTop="@drawable/ic_widget_silence_20"
            android:drawablePadding="3dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp"
            android:text="@string/widget_btn_silence_short"
            android:textColor="@color/rg_orange"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_btn_indefinite"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_purple"
            android:drawableTop="@drawable/ic_widget_indefinite_20"
            android:drawablePadding="3dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp"
            android:text="@string/widget_btn_indefinite_short"
            android:textColor="@color/rg_purple"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_btn_ring"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_green"
            android:drawableTop="@drawable/ic_widget_ringer_on_20"
            android:drawablePadding="3dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingHorizontal="4dp"
            android:paddingVertical="4dp"
            android:text="@string/widget_btn_enable_short"
            android:textColor="@color/rg_green"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
