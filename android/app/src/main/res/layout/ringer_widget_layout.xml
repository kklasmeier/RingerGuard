<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rg_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textAllCaps="true"
            android:textColor="@color/rg_text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/rg_status_green_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/widget_ringing"
            android:textColor="@color/rg_green"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_countdown_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/rg_orange"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_countdown_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_countdown_label"
            android:textColor="@color/rg_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_btn_silence"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@color/rg_status_orange_bg"
            android:gravity="center"
            android:padding="10dp"
            android:text="@string/action_silence_duration"
            android:textColor="@color/rg_orange"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_btn_indefinite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@color/rg_status_purple_bg"
            android:gravity="center"
            android:padding="10dp"
            android:text="@string/action_indefinite"
            android:textColor="@color/rg_purple"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_btn_ring"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@color/rg_status_green_bg"
            android:gravity="center"
            android:padding="10dp"
            android:text="@string/action_ring_now"
            android:textColor="@color/rg_green"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
