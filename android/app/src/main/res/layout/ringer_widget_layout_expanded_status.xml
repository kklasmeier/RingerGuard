<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rg_surface"
    android:baselineAligned="false"
    android:orientation="vertical"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/rg_text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/widget_status_dot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="@string/widget_status_indicator"
            android:src="@drawable/status_dot_green" />

        <TextView
            android:id="@+id/widget_status_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_silenced"
            android:textColor="@color/rg_orange"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_center_section"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/widget_countdown_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <Chronometer
                android:id="@+id/widget_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/rg_orange"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_countdown_static"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/rg_orange"
                android:textSize="28sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_countdown_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_countdown_label"
                android:textColor="@color/rg_text_secondary"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_button_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_btn_silence"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_orange"
            android:drawableTop="@drawable/ic_widget_silence_20"
            android:drawablePadding="4dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:minHeight="56dp"
            android:paddingHorizontal="4dp"
            android:paddingVertical="6dp"
            android:text="@string/action_silence_duration"
            android:textColor="@color/rg_orange"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_btn_indefinite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_purple"
            android:drawableTop="@drawable/ic_widget_indefinite_20"
            android:drawablePadding="4dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:minHeight="56dp"
            android:paddingHorizontal="4dp"
            android:paddingVertical="6dp"
            android:text="@string/action_indefinite"
            android:textColor="@color/rg_purple"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_btn_ring"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_green"
            android:drawableTop="@drawable/ic_widget_ringer_on_20"
            android:drawablePadding="4dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:minHeight="56dp"
            android:paddingHorizontal="4dp"
            android:paddingVertical="6dp"
            android:text="@string/action_ring_now_short"
            android:textColor="@color/rg_green"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
