    <string name="welcome_title">Welcome to RingerGuard</string>
    <string name="welcome_body">RingerGuard keeps your ringer on unless you explicitly silence it. After a grace period, it restores volume automatically.</string>

    <string name="phone_disclosure_title">Why RingerGuard needs phone access</string>
    <string name="phone_disclosure_body">RingerGuard detects when you dismiss an incoming call (without answering) so it can start a grace period before restoring your ringer.\n\nRingerGuard does not access your phone number, call history, or contacts. This permission is optional.</string>
